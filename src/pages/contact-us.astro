---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ContactInfo from "../components/ContactInfo.astro";
import { business } from "../data/business";

const seo = {
  title: "Contact Mayan Stonecrafters, Inc. | Melbourne, FL",
  description:
    "Contact Mayan Stonecrafters in Melbourne, FL for a free countertop estimate. Two locations serving Brevard County. Call us at (321) 821-4381.",
  keywords:
    "contact Mayan Stonecrafters, countertop estimate Melbourne FL, free estimate, countertop contractors Brevard County, Melbourne countertops phone, Indian Harbour Beach, stone fabricators contact, Mayan Stonecrafters",
  path: "/contact-us/",
};
---

<BaseLayout seo={seo}>
  <Hero
    eyebrow="Get in Touch"
    title="Contact Mayan Stonecrafters, Inc."
    subtitle="Located in Melbourne, servicing Melbourne, Merritt Island, Viera and surrounding areas. Contact us now to get a free estimate."
    image="/images/contact-intro.jpg"
    imageAlt="Stone countertop detail by Mayan Stonecrafters"
    compact={true}
  />

  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl md:text-3xl">Request a Free Estimate</h2>
        <p class="mt-4 text-charcoal/80">
          Fill out the form below and one of our consultants will get back to you.
        </p>
        <div class="mt-6">
          <script src="https://hyppohq.io/api/v1/forms/embed/mayan-stonecrafters/contact-mayn-stonecrafters" async></script>
          <noscript>
            <p>
              Please <a href={business.contactFormUrl} class="text-accent underline">open our contact form</a> or call
              <a href={business.phoneHref} class="text-accent underline">{business.phone}</a>.
            </p>
          </noscript>
        </div>
      </div>

      <div>
        <h2 class="font-display text-2xl md:text-3xl">Visit or Call Us</h2>
        <div class="mt-6">
          <ContactInfo />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-stone-soft/40 py-12">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <h2 class="font-display text-xl">Accepted Payment Methods</h2>
      <p class="mt-3 text-charcoal/80">{business.payments.join(" · ")}</p>
    </div>
  </section>
</BaseLayout>
