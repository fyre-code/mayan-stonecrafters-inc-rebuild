---
import { business } from "../data/business";
---

<div class="grid gap-8 sm:grid-cols-2">
  {
    business.locations.map((loc, i) => (
      <div class="rounded-lg border border-stone/40 bg-paper p-6">
        <h3 class="font-display text-xl">{i === 0 ? "Main Location" : "Second Location"}</h3>
        <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-accent">{loc.name}</p>
        <address class="mt-3 not-italic leading-relaxed text-charcoal">
          {loc.address}
          <br />
          {loc.cityStateZip}
        </address>
        <p class="mt-3">
          <a href={`tel:${loc.phone.replace(/[^0-9]/g, "")}`} class="font-semibold hover:text-accent">
            {loc.phone}
          </a>
        </p>
        <ul class="mt-3 space-y-0.5 text-sm text-charcoal/80">
          {loc.hours.map((h) => <li>{h}</li>)}
        </ul>
      </div>
    ))
  }
</div>
<p class="mt-6 text-center text-charcoal/80">
  Email us at <a href={`mailto:${business.email}`} class="font-semibold text-accent hover:underline">{business.email}</a>
</p>
