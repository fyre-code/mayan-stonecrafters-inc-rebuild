---
import { business } from "../data/business";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  compact?: boolean;
  showCtas?: boolean;
}
const {
  eyebrow,
  title,
  subtitle,
  image = "/images/kitchen-with-stone-countertops-hero.jpg",
  imageAlt = "Kitchen with custom stone countertops",
  compact = false,
  showCtas = false,
} = Astro.props;
---

<section
  class={`relative isolate overflow-hidden bg-charcoal text-paper ${compact ? "py-20 md:py-28" : "py-28 md:py-40"}`}
>
  <!-- Animated stone background -->
  <div class="absolute inset-0 -z-10">
    <img
      src={image}
      alt={imageAlt}
      class="hero-bg h-full w-full object-cover opacity-40"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/80 to-charcoal/30"></div>
    <!-- Polished-edge light sweep -->
    <div class="hero-sweep pointer-events-none absolute inset-y-0 -left-1/3 w-1/3 bg-gradient-to-r from-transparent via-paper/25 to-transparent"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4">
    {eyebrow && (
      <p class="hero-rise mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-accent">
        {eyebrow}
      </p>
    )}
    <h1 class={`hero-rise-2 max-w-4xl font-display ${compact ? "text-4xl md:text-5xl" : "text-5xl md:text-7xl"}`}>
      {title}
    </h1>
    <div class="accent-bar mt-5 h-1 w-28 bg-accent"></div>
    {subtitle && (
      <p class="hero-rise-3 mt-6 max-w-2xl text-lg text-paper/85">{subtitle}</p>
    )}

    {showCtas && (
      <div class="hero-rise-3 mt-9 flex flex-wrap gap-4">
        <a
          href={business.phoneHref}
          class="inline-flex items-center rounded bg-accent px-7 py-3 font-bold uppercase tracking-wide text-paper transition-transform hover:scale-105"
        >
          Call {business.phone}
        </a>
        <a
          href={business.contactFormUrl}
          class="inline-flex items-center rounded border border-paper/40 px-7 py-3 font-bold uppercase tracking-wide text-paper transition-colors hover:border-accent hover:text-accent"
        >
          Message Us
        </a>
      </div>
    )}
  </div>
</section>
