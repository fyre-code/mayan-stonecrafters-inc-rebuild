---
import { business } from "../data/business";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  compact?: boolean;
  showCtas?: boolean;
}
const {
  eyebrow,
  title,
  subtitle,
  image = "/images/kitchen-with-stone-countertops-hero.jpg",
  imageAlt = "Kitchen with custom stone countertops",
  compact = false,
  showCtas = false,
} = Astro.props;
---

<section
  class={`relative isolate flex items-center overflow-hidden bg-charcoal text-paper ${compact ? "py-20 md:py-28" : "min-h-[80svh] py-10"}`}
>
  <!-- Animated stone background -->
  <div class="absolute inset-0 -z-10">
    <img
      src={image}
      alt={imageAlt}
      class="hero-bg h-full w-full object-cover opacity-65"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/60 via-charcoal/45 to-charcoal/60"></div>
    <!-- Polished-edge light sweep -->
    <div class="hero-sweep pointer-events-none absolute inset-y-0 -left-1/2 w-1/2 bg-gradient-to-r from-transparent via-paper/55 to-transparent"></div>
  </div>

  <div class="mx-auto w-full max-w-4xl px-4 text-center">
    <h1 class={`hero-rise-2 mx-auto font-display ${compact ? "text-4xl md:text-5xl" : "text-5xl md:text-7xl"}`}>
      {title}
    </h1>
    {subtitle && (
      <p class="hero-rise-3 mx-auto mt-6 max-w-4xl text-lg text-paper/85">{subtitle}</p>
    )}

    {showCtas && (
      <div class="hero-rise-3 mx-auto mt-9 flex max-w-xs flex-col items-stretch gap-4">
        <a
          href={business.phoneHref}
          class="inline-flex items-center justify-center rounded bg-accent px-7 py-3 font-bold uppercase tracking-wide text-paper transition-transform hover:scale-105"
        >
          Call {business.phone}
        </a>
        <a
          href={business.contactFormUrl}
          class="inline-flex items-center justify-center rounded border border-paper/40 px-7 py-3 font-bold uppercase tracking-wide text-paper transition-colors hover:border-accent hover:text-accent"
        >
          Message Us
        </a>
      </div>
    )}
  </div>
</section>
