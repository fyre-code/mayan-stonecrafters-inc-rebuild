---
import { business } from "../data/business";
---

<section class="bg-paper">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <h2 class="mb-8 text-2xl md:text-3xl">Our Products</h2>
    <div class="flex flex-wrap items-center justify-center gap-x-14 gap-y-8">
      {
        business.brandPartners.map((b) => (
          <img src={b.src} alt={b.alt} class="h-40 w-auto opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0 md:h-48" loading="lazy" />
        ))
      }
    </div>
  </div>
</section>
