---
import { business, services } from "../data/business";
import { areas } from "../data/areas";
---

<footer class="mt-24 bg-charcoal text-paper/90">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-3">
        <img src={business.logo} alt="Mayan Stonecrafters, Inc. logo" width="44" height="44" class="h-11 w-11" />
        <span class="font-display text-lg">{business.name}</span>
      </div>
      <p class="mt-4 text-sm text-paper/70">{business.tagline}</p>
      <div class="mt-4 flex gap-3">
        <a href={business.social.instagram} class="text-sm underline hover:text-accent" rel="noopener" target="_blank">Instagram</a>
        <a href={business.social.facebook} class="text-sm underline hover:text-accent" rel="noopener" target="_blank">Facebook</a>
      </div>
    </div>

    {
      business.locations.map((loc) => (
        <div>
          <h3 class="font-display text-sm tracking-wide text-accent">{loc.name}</h3>
          <address class="mt-3 not-italic text-sm leading-relaxed text-paper/80">
            {loc.address}
            <br />
            {loc.cityStateZip}
            <br />
            <a href={`tel:${loc.phone.replace(/[^0-9]/g, "")}`} class="hover:text-accent">{loc.phone}</a>
          </address>
          <ul class="mt-3 space-y-0.5 text-xs text-paper/60">
            {loc.hours.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      ))
    }

    <div>
      <h3 class="font-display text-sm tracking-wide text-accent">Services</h3>
      <ul class="mt-3 space-y-1 text-sm text-paper/80">
        {services.slice(0, 6).map((s) => (
          <li><a href={`/services/${s.slug}/`} class="hover:text-accent">{s.title}</a></li>
        ))}
        <li><a href="/areas-we-serve/" class="hover:text-accent">Areas We Serve</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div class="mx-auto max-w-7xl px-4 py-4 text-center text-xs text-paper/50">
      <p class="mb-2">
        Accepted payments: {business.payments.join(" · ")}
      </p>
      <p>© {new Date().getFullYear()} {business.name} All Rights Reserved.</p>
    </div>
  </div>
</footer>
