---
import { business } from "../data/business";
---

<footer class="bg-[#4A798F] text-paper/90">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 text-center md:grid-cols-2 lg:grid-cols-4">
    <div class="flex flex-col items-center">
      <img src={business.logo} alt="Mayan Stonecrafters, Inc. logo" width="154" height="154" class="h-[154px] w-[154px]" />
      <span class="mt-3 font-display text-lg">{business.name}</span>
    </div>

    {
      business.locations.map((loc) => (
        <div>
          <h3 class="font-display text-sm tracking-wide text-accent">{loc.name}</h3>
          <address class="mt-3 not-italic text-sm leading-relaxed text-paper/80">
            {loc.address}
            <br />
            {loc.cityStateZip}
            <br />
            <a href={`tel:${loc.phone.replace(/[^0-9]/g, "")}`} class="hover:text-accent">{loc.phone}</a>
          </address>
          <ul class="mt-3 space-y-0.5 text-xs text-paper/60">
            {loc.hours.map((h) => <li>{h}</li>)}
          </ul>
        </div>
      ))
    }

    <div>
      <h3 class="font-display text-sm tracking-wide text-accent">Follow Us</h3>
      <ul class="mt-3 space-y-3 text-sm text-paper/80">
        <li>
          <a href={business.social.instagram} class="flex items-center justify-center gap-3 hover:text-accent" rel="noopener" target="_blank">
            <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.5.01-4.74.07-.9.04-1.38.19-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.13.33-.28.81-.32 1.71-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.04.9.19 1.38.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.33.13.81.28 1.71.32 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.9-.04 1.38-.19 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.13-.33.28-.81.32-1.71.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.9-.19-1.38-.32-1.71a2.85 2.85 0 0 0-.69-1.06 2.85 2.85 0 0 0-1.06-.69c-.33-.13-.81-.28-1.71-.32-1.24-.06-1.59-.07-4.74-.07Zm0 2.76a5.46 5.46 0 1 1 0 10.92 5.46 5.46 0 0 1 0-10.92Zm0 9a3.54 3.54 0 1 0 0-7.08 3.54 3.54 0 0 0 0 7.08Zm6.95-9.22a1.28 1.28 0 1 1-2.55 0 1.28 1.28 0 0 1 2.55 0Z"/>
            </svg>
            <span>Instagram</span>
          </a>
        </li>
        <li>
          <a href={business.social.facebook} class="flex items-center justify-center gap-3 hover:text-accent" rel="noopener" target="_blank">
            <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z"/>
            </svg>
            <span>Facebook</span>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-paper/10">
    <div class="mx-auto max-w-7xl px-4 py-4 text-center text-xs text-paper/50">
      <p class="mb-2">
        Accepted payments: {business.payments.join(" · ")}
      </p>
      <p>© {new Date().getFullYear()} {business.name} All Rights Reserved.</p>
      <p class="mt-1">
        Powered by
        <a href="https://hyppohq.ai" class="hover:text-accent" rel="noopener" target="_blank">HyppoAI</a>
      </p>
    </div>
  </div>
</footer>
