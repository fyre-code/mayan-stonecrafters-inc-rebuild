---
import Hero from "./Hero.astro";
import CtaBand from "./CtaBand.astro";
import Badges from "./Badges.astro";
import { business } from "../data/business";

export interface Section {
  heading?: string;
  level?: 2 | 3;
  paras?: string[];
  list?: string[];
}
export interface Faq {
  q: string;
  a: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  intro: string[];
  sections: Section[];
  faqs?: Faq[];
  image?: string;
  imageAlt?: string;
  introImage?: string;
  introImageAlt?: string;
}
const {
  eyebrow,
  title,
  intro,
  sections,
  faqs = [],
  image,
  imageAlt,
  introImage,
  introImageAlt,
} = Astro.props;
---

<Hero eyebrow={eyebrow} title={title} image={image} imageAlt={imageAlt} compact={true} />

<article class="mx-auto max-w-5xl px-4 py-16">
  <div class={introImage ? "grid items-start gap-10 lg:grid-cols-[1fr_minmax(0,420px)]" : ""}>
    <div>
      {intro.map((p) => <p class="mb-5 text-lg leading-relaxed text-charcoal/85">{p}</p>)}

      <a
        href={business.phoneHref}
        class="my-2 inline-flex items-center rounded bg-accent px-6 py-3 font-bold uppercase tracking-wide text-paper transition-transform hover:scale-105"
      >
        Call {business.phone}
      </a>
    </div>
    {introImage && (
      <img
        src={introImage}
        alt={introImageAlt ?? title}
        class="reveal w-full rounded-xl object-cover shadow-lg lg:sticky lg:top-28"
        loading="lazy"
      />
    )}
  </div>

  {
    sections.map((s) => (
      <section class="reveal mt-12">
        {s.heading &&
          (s.level === 3 ? (
            <h3 class="font-display text-xl text-charcoal">{s.heading}</h3>
          ) : (
            <h2 class="font-display text-2xl md:text-3xl">
              {s.heading}
            </h2>
          ))}
        {s.paras?.map((p) => <p class="mt-4 leading-relaxed text-charcoal/85">{p}</p>)}
        {s.list && (
          <ul class="mt-4 grid gap-2 sm:grid-cols-2">
            {s.list.map((li) => (
              <li class="flex gap-2 text-charcoal/85">
                <span class="mt-1 text-accent">▪</span>
                <span>{li}</span>
              </li>
            ))}
          </ul>
        )}
      </section>
    ))
  }

  {
    faqs.length > 0 && (
      <section class="mt-16">
        <h2 class="font-display text-2xl md:text-3xl">FAQs</h2>
        <div class="mt-6 divide-y divide-stone/40">
          {faqs.map((f) => (
            <details class="group py-4">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg">
                {f.q}
                <span class="text-accent transition-transform group-open:rotate-45">+</span>
              </summary>
              <p class="mt-3 text-charcoal/80">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    )
  }
</article>

<Badges />
<CtaBand />
