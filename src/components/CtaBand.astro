---
import { business } from "../data/business";
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Ready For A Project?",
  text = "Contact us now to get a free estimate.",
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-accent text-paper">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-4 py-16 text-center md:flex-row md:justify-between md:text-left">
    <div>
      <h2 class="font-display text-3xl md:text-4xl">{heading}</h2>
      <p class="mt-2 text-paper/90">{text}</p>
    </div>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={business.phoneHref} class="rounded bg-ink px-7 py-3 font-bold uppercase tracking-wide transition-transform hover:scale-105">
        Call {business.phone}
      </a>
      <a href={business.contactFormUrl} class="rounded border-2 border-paper px-7 py-3 font-bold uppercase tracking-wide transition-colors hover:bg-paper hover:text-accent">
        Message Us
      </a>
    </div>
  </div>
</section>
